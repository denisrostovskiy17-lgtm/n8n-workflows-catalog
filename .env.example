# Anthropic API — for Claude calls inside HTTP Request nodes
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Telegram — bot token is configured in n8n credentials UI;
# this is the chat ID(s) you post to.
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_OPS_CHAT_ID=-1009876543210

# Klaviyo — private API key for profile updates
# Get yours at https://www.klaviyo.com/account#api-keys-tab
KLAVIYO_API_KEY=pk_...
